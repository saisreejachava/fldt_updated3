{
  "name": "jaxtwin-landing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=6144 ./node_modules/vite/bin/vite.js build",
